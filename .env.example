# Supabase — העתק קובץ זה ל־.env.local ומלא את הערכים מפרויקט ה־Supabase שלך
# Settings > API בפרויקט Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# אם המשתנים ריקים / חסרים — האפליקציה עוברת אוטומטית למצב מקומי (localStorage)
# כך אפשר להריץ ולבדוק את האפליקציה גם ללא חיבור ל־Supabase.
